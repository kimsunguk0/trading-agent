ENVIRONMENT=paper
OPERATING_MODE=LIVE_APPROVAL
APP_MODE=READ_ONLY
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=paper.events
DATABASE_URL=postgresql://stock:stock@localhost:5432/stock
POLL_INTERVAL_SECONDS=1
BROKER_NAME=simulated
BROKER_ADAPTER=simulated
# Set BROKER_ADAPTER=kiwoom_mock to use Kiwoom REST mock trading.
KIWOOM_BASE_URL=https://mockapi.kiwoom.com
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=
# Optional preserved KIS domestic KR adapter: BROKER_ADAPTER=kis_kr_mock
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
# Toss Invest Open API is live-only; BROKER_ADAPTER=toss sends real-cash orders.
TOSS_BASE_URL=https://openapi.tossinvest.com
TOSS_APP_KEY=
TOSS_APP_SECRET=
TOSS_ACCOUNT_NO=
DART_API_KEY=
EMBEDDING_API_URL=http://localhost:8001
QDRANT_URL=http://qdrant:6333
LLM_API_URL=http://localhost:8000/v1
LLM_MODEL=Qwen3-30B-A3B-Instruct-2507
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
KIS_LIVE_ACCOUNT_NO=

KIWOOM_LIVE_APP_KEY=
KIWOOM_LIVE_APP_SECRET=
KIWOOM_LIVE_ACCOUNT_NO=
